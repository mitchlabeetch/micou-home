{
  "micou_environment": {
    "primary_domain": "micou.org",
    "member_portal_url": "https://micou.org/yunohost/sso/",
    "public_homepage_root": "/srv/micou-services/micou-homepage/app",
    "registry_data_root": "/srv/micou-services/micou-homepage/data",
    "managed_services_root": "/srv/micou-services",
    "default_install_dir_pattern": "/var/www/__APP__",
    "default_data_dir_pattern": "/var/yunohost.app/__APP__"
  },
  "shared_defaults": {
    "maintainer": "micou",
    "ask_domain_path": true,
    "ask_access_group": true,
    "ask_admin_access_group": true,
    "multi_instance": false,
    "init_system_user": true,
    "init_install_dir": true,
    "init_data_dir": true,
    "init_database": false,
    "auto_source_updates": true,
    "supports_change_url": true,
    "supports_fail2ban": false,
    "supports_cron": false,
    "integrates_ldap": false,
    "integrates_sso": false,
    "apt_dependencies": [],
    "micou_rules": [
      "Keep public discovery on micou.org and authenticated launching in the YunoHost portal.",
      "Document privacy limitations, auth behavior, and reverse-proxy assumptions in package docs.",
      "Mirror package deployment metadata back into the micou service registry after installation."
    ]
  },
  "official_generator": {
    "url": "https://appgenerator.yunohost.org/",
    "version": "0.21.0",
    "sections": [
      "General information",
      "Upstream information",
      "Integration in YunoHost",
      "Questions to ask during installation",
      "Resources to initialize",
      "App build and configuration",
      "Advanced options"
    ],
    "extra_fields_tracked_by_micou": [
      "code_repository",
      "packaging_format",
      "architectures",
      "app_main_technology",
      "source_type",
      "automatic_source_updates",
      "database_engine",
      "use_yarn",
      "cron_expression",
      "cron_command",
      "homepage_visibility",
      "member_portal_visibility",
      "runtime_notes",
      "storage_notes",
      "auth_notes"
    ]
  },
  "profiles": {
    "tutorial": {
      "generator_mode": "tutorial",
      "description": "Use for first-pass packages and learning-oriented package repos.",
      "code_style": "commented",
      "recommended_for": [
        "new custom services",
        "apps with uncertain auth integration",
        "packages that need review by multiple maintainers"
      ]
    },
    "streamlined": {
      "generator_mode": "streamlined",
      "description": "Use for stable service patterns and production-clean package repositories.",
      "code_style": "minimal",
      "recommended_for": [
        "repeatable packaging patterns",
        "mature micou services",
        "known upstream runtimes"
      ]
    }
  }
}
